{
	"name": "supremacy",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "CLOUDFLARE_ENV=dev vite dev --host 0.0.0.0",
		"build": "vite build",
		"typecheck": "tsc -b",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint .",
		"cf-typegen": "wrangler types",
		"deploy:dev": "CLOUDFLARE_ENV=dev vite build && wrangler deploy",
		"deploy:test": "CLOUDFLARE_ENV=test vite build && wrangler deploy",
		"deploy": "CLOUDFLARE_ENV=production vite build && wrangler deploy"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.38.0",
		"@cloudflare/vitest-pool-workers": "^0.16.9",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"wrangler": "^4.94.0"
	},
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"@headlessui/react": "^2.2.10",
		"@heroicons/react": "^2.2.0",
		"@tailwindcss/vite": "^4.3.0",
		"globals": "^17.6.0",
		"itty-router": "^5.0.23",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router": "^7.15.1",
		"tailwindcss": "^4.3.0"
	}
}
